{
  "name": "polena",
  "version": "0.1.0",
  "description": "Polena programming language compiler",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "polena": "src/index.ts"
  },
  "license": "MIT",
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": ">=1.3.13"
  },
  "scripts": {
    "check": "bun run typecheck && bun run lint && bun run format:check && bun run test",
    "compile": "bun run src/index.ts compile",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "test": "bun test --pass-with-no-tests",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
