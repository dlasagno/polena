{
  "name": "polena-vscode",
  "displayName": "Polena",
  "description": "Language support for Polena source files.",
  "version": "0.0.1",
  "publisher": "polena",
  "license": "MIT",
  "type": "module",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "scripts": {
    "build": "bun build ../language-server/src/index.ts --outfile ./dist/server.js --target node && bun build ./src/extension.ts --outfile ./dist/extension.js --target node --external vscode",
    "build:vsix": "bun run build && vsce package --no-dependencies",
    "check": "bun run build",
    "package": "bun run build:vsix"
  },
  "categories": [
    "Programming Languages"
  ],
  "files": [
    "dist",
    "language-configuration.json",
    "syntaxes",
    "README.md"
  ],
  "keywords": [
    "polena",
    "syntax-highlighting",
    "language"
  ],
  "contributes": {
    "languages": [
      {
        "id": "polena",
        "aliases": [
          "Polena",
          "polena"
        ],
        "extensions": [
          ".plna",
          ".polena"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "polena",
        "scopeName": "source.polena",
        "path": "./syntaxes/polena.tmLanguage.json"
      }
    ]
  },
  "devDependencies": {
    "@types/vscode": "1.85.0",
    "@vscode/vsce": "^3.9.1"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
