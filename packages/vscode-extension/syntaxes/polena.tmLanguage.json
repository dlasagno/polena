{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Polena",
  "scopeName": "source.polena",
  "patterns": [
    {
      "include": "#doc-comments"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#multiline-string"
    },
    {
      "include": "#double-quoted-string"
    },
    {
      "include": "#directives"
    },
    {
      "include": "#import-declaration"
    },
    {
      "include": "#function-declaration"
    },
    {
      "include": "#type-declaration"
    },
    {
      "include": "#variable-declaration"
    },
    {
      "include": "#reserved-keywords"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#object-field-name"
    },
    {
      "include": "#booleans"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#function-call"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "doc-comments": {
      "patterns": [
        {
          "name": "comment.line.documentation.module.polena",
          "match": "//!.*$"
        },
        {
          "name": "comment.line.documentation.polena",
          "match": "///.*$"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.polena",
          "match": "//(?![/!]).*$"
        }
      ]
    },
    "double-quoted-string": {
      "patterns": [
        {
          "name": "string.quoted.double.polena",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.polena"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.polena"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.polena",
              "match": "\\\\(?:0|t|n|r|\"|\\\\)"
            },
            {
              "include": "#interpolation"
            }
          ]
        }
      ]
    },
    "multiline-string": {
      "patterns": [
        {
          "name": "string.quoted.other.multiline.polena",
          "begin": "^(\\s*)(\\\\\\\\)",
          "beginCaptures": {
            "2": {
              "name": "punctuation.definition.string.begin.polena"
            }
          },
          "end": "$",
          "patterns": [
            {
              "name": "constant.character.escape.polena",
              "match": "\\\\(?:0|t|n|r|\"|\\\\)"
            },
            {
              "include": "#interpolation"
            }
          ]
        }
      ]
    },
    "interpolation": {
      "patterns": [
        {
          "begin": "\\$\\{",
          "beginCaptures": {
            "0": {
              "name": "punctuation.section.embedded.begin.polena"
            }
          },
          "end": "\\}",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.embedded.end.polena"
            }
          },
          "contentName": "meta.embedded.expression.polena",
          "patterns": [
            {
              "include": "#expression"
            }
          ]
        }
      ]
    },
    "expression": {
      "patterns": [
        {
          "include": "#double-quoted-string"
        },
        {
          "include": "#directives"
        },
        {
          "include": "#reserved-keywords"
        },
        {
          "include": "#keywords"
        },
        {
          "include": "#types"
        },
        {
          "include": "#object-field-name"
        },
        {
          "include": "#booleans"
        },
        {
          "include": "#numbers"
        },
        {
          "include": "#function-call"
        },
        {
          "include": "#identifiers"
        },
        {
          "include": "#operators"
        },
        {
          "include": "#punctuation"
        },
        {
          "include": "#interpolation"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "meta.directive.polena",
          "match": "(@)([A-Za-z_$][A-Za-z0-9_$]*)\\b",
          "captures": {
            "1": {
              "name": "punctuation.definition.directive.polena"
            },
            "2": {
              "name": "entity.name.function.directive.polena"
            }
          }
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.readwrite.polena",
          "match": "\\b[A-Za-z_$][A-Za-z0-9_$]*\\b"
        }
      ]
    },
    "import-declaration": {
      "patterns": [
        {
          "name": "meta.import.polena",
          "begin": "\\b(import)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.declaration.import.polena"
            }
          },
          "end": ";",
          "endCaptures": {
            "0": {
              "name": "punctuation.terminator.statement.polena"
            }
          },
          "patterns": [
            {
              "name": "string.unquoted.module-path.polena",
              "match": "(?:@std|@)(?:/[A-Za-z_$][A-Za-z0-9_$]*)*|[A-Za-z_$][A-Za-z0-9_$]*(?:/[A-Za-z_$][A-Za-z0-9_$]*)+"
            },
            {
              "name": "keyword.declaration.type.polena",
              "match": "\\btype\\b"
            },
            {
              "name": "keyword.declaration.alias.polena",
              "match": "\\bas\\b"
            },
            {
              "name": "variable.other.import.polena",
              "match": "\\b[A-Za-z_$][A-Za-z0-9_$]*\\b"
            },
            {
              "include": "#punctuation"
            }
          ]
        }
      ]
    },
    "function-declaration": {
      "patterns": [
        {
          "name": "meta.function.declaration.polena",
          "begin": "\\b(fn)\\b\\s+([A-Za-z_$][A-Za-z0-9_$]*)\\s*(?:<[^>]*>\\s*)?(\\()",
          "beginCaptures": {
            "1": {
              "name": "keyword.declaration.function.polena"
            },
            "2": {
              "name": "entity.name.function.polena"
            },
            "3": {
              "name": "punctuation.section.parameters.begin.polena"
            }
          },
          "end": "\\)",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.parameters.end.polena"
            }
          },
          "patterns": [
            {
              "name": "variable.parameter.polena",
              "match": "\\b[A-Za-z_$][A-Za-z0-9_$]*\\b(?=\\s*:)"
            },
            {
              "name": "punctuation.separator.type.polena",
              "match": ":"
            },
            {
              "name": "punctuation.separator.parameter.polena",
              "match": ","
            },
            {
              "include": "#types"
            }
          ]
        }
      ]
    },
    "variable-declaration": {
      "patterns": [
        {
          "name": "meta.variable.declaration.polena",
          "match": "\\b(const|let)\\b\\s+([A-Za-z_$][A-Za-z0-9_$]*)",
          "captures": {
            "1": {
              "name": "storage.modifier.polena"
            },
            "2": {
              "name": "variable.other.readwrite.polena"
            }
          }
        }
      ]
    },
    "type-declaration": {
      "patterns": [
        {
          "name": "meta.type.declaration.polena",
          "match": "\\b(type)\\b\\s+([A-Za-z_$][A-Za-z0-9_$]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.type.polena"
            },
            "2": {
              "name": "entity.name.type.polena"
            }
          }
        }
      ]
    },
    "object-field-name": {
      "patterns": [
        {
          "name": "variable.other.member.polena",
          "match": "\\b[A-Za-z_$][A-Za-z0-9_$]*\\b(?=\\s*:)"
        }
      ]
    },
    "reserved-keywords": {
      "patterns": [
        {
          "name": "keyword.other.reserved.polena",
          "match": "\\b(?:comptime|impl|trait|unknown)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.polena",
          "match": "\\b(?:break|continue|else|if|match|return|while)\\b"
        },
        {
          "name": "keyword.declaration.enum.polena",
          "match": "\\benum\\b"
        },
        {
          "name": "keyword.declaration.module.polena",
          "match": "\\b(?:as|export|import)\\b"
        },
        {
          "name": "keyword.operator.word.polena",
          "match": "\\b(?:and|or)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.polena",
          "match": "\\b(?:bigint|boolean|number|string|void)\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.polena",
          "match": "\\b(?:false|true)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.hexadecimal.bigint.polena",
          "match": "\\b0[xX][0-9A-Fa-f](?:_?[0-9A-Fa-f])*n\\b"
        },
        {
          "name": "constant.numeric.integer.octal.bigint.polena",
          "match": "\\b0[oO][0-7](?:_?[0-7])*n\\b"
        },
        {
          "name": "constant.numeric.integer.binary.bigint.polena",
          "match": "\\b0[bB][01](?:_?[01])*n\\b"
        },
        {
          "name": "constant.numeric.integer.decimal.bigint.polena",
          "match": "\\b\\d(?:_?\\d)*(?:[eE][+-]?\\d(?:_?\\d)*)?n\\b"
        },
        {
          "name": "constant.numeric.integer.hexadecimal.polena",
          "match": "\\b0[xX][0-9A-Fa-f](?:_?[0-9A-Fa-f])*\\b"
        },
        {
          "name": "constant.numeric.integer.octal.polena",
          "match": "\\b0[oO][0-7](?:_?[0-7])*\\b"
        },
        {
          "name": "constant.numeric.integer.binary.polena",
          "match": "\\b0[bB][01](?:_?[01])*\\b"
        },
        {
          "name": "constant.numeric.number.polena",
          "match": "\\b\\d(?:_?\\d)*(?:\\.\\d(?:_?\\d)*)?(?:[eE][+-]?\\d(?:_?\\d)*)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.polena",
          "match": "=>|==|!=|<=|>=|\\+\\+|\\+=|-=|\\*=|/=|%=|=|<|>|\\+|-|\\*|/|%|!"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "name": "entity.name.function.call.polena",
          "match": "\\b[A-Za-z_$][A-Za-z0-9_$]*\\b(?=\\s*\\()"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.colon.polena",
          "match": ":"
        },
        {
          "name": "punctuation.separator.comma.polena",
          "match": ","
        },
        {
          "name": "punctuation.accessor.dot.polena",
          "match": "\\."
        },
        {
          "name": "punctuation.definition.directive.polena",
          "match": "@"
        },
        {
          "name": "constant.language.wildcard.polena",
          "match": "\\b_\\b"
        },
        {
          "name": "punctuation.terminator.statement.polena",
          "match": ";"
        },
        {
          "name": "punctuation.section.block.begin.polena",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.block.end.polena",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.group.begin.polena",
          "match": "\\("
        },
        {
          "name": "punctuation.section.group.end.polena",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.brackets.begin.polena",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.polena",
          "match": "\\]"
        }
      ]
    }
  }
}
